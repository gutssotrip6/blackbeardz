# Meta Pixel Configuration
# Get from: https://facebook.com/business/pixel
NEXT_PUBLIC_META_PIXEL_ID=your-meta-pixel-id

# Meta Conversions API Configuration (Server-side)
# Get from: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=your-meta-access-token
META_PIXEL_ID=your-meta-pixel-id

# TikTok Pixel Configuration
# Get from: https://ads.tiktok.com/pixel
NEXT_PUBLIC_TIKTOK_PIXEL_ID=your-tiktok-pixel-id

# TikTok Events API Configuration (Server-side)
# Get from: https://ads.tiktok.com/spark/ad/overview
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
TIKTOK_PIXEL_ID=your-tiktok-pixel-id

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# WooCommerce Configuration
# Get from: WordPress Admin → WooCommerce → Settings → Advanced → REST API
# Create API keys with Read/Write permissions
NEXT_PUBLIC_WOOCOMMERCE_URL=https://your-woocommerce-site.com
NEXT_PUBLIC_WOOCOMMERCE_CONSUMER_KEY=ck_your-consumer-key
NEXT_PUBLIC_WOOCOMMERCE_CONSUMER_SECRET=cs_your-consumer-secret

# WooCommerce Image Domain (for Next.js image optimization)
# This should be the same as NEXT_PUBLIC_WOOCOMMERCE_URL without the protocol
WOOCOMMERCE_IMAGE_DOMAIN=your-woocommerce-site.com
